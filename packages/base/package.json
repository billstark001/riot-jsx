{
  "name": "@riot-jsx/base",
  "version": "0.1.2",
  "description": "Core types, connector factory and CSS scoping utilities for riot-jsx",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/billstark001/riot-jsx.git",
    "directory": "packages/base"
  },
  "type": "module",
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "rollup -c rollup.config.ts --configPlugin @rollup/plugin-typescript",
    "test": "vitest",
    "test:run": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "stylis": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "stylis": { "optional": true }
  },
  "devDependencies": {
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "jsdom": "^29.0.2",
    "rollup": "^4.60.2",
    "rollup-plugin-dts": "^6.4.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  }
}
