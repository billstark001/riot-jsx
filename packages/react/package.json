{
  "name": "@riot-jsx/react",
  "version": "0.1.2",
  "description": "React 18 and React 17 renderer adapters and RiotMount component for riot-jsx",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/billstark001/riot-jsx.git",
    "directory": "packages/react"
  },
  "type": "module",
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rollup -c rollup.config.ts --configPlugin @rollup/plugin-typescript",
    "test": "vitest",
    "test:run": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@riot-jsx/base": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=16.8.0",
    "react-dom": ">=16.8.0",
    "riot": ">=4.0.0"
  },
  "devDependencies": {
    "@riot-jsx/base": "workspace:*",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "jsdom": "^29.0.2",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "riot": "^10.1.3",
    "rollup": "^4.60.2",
    "rollup-plugin-dts": "^6.4.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  }
}
